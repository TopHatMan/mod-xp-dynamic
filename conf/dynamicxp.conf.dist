[worldserver]

################################################################################################################
#    Dynamic.XP.Rate
#        Description: You can setup the personal XP rate for different level ranges.
#
#        Dynamic.XP.Rate.Announce: 1 (Enable) Default
#                                  0 (Disable)
#
#        Dynamic.XP.Rate: 1 (Enable) Default
#                         0 (Disable)
#
#        Dynamic.XP.Rate.X-X: 1+ (Set a custom XP rate on that level range)
#                             0  (Reset custom XP rate to default on that level range)
#


Dynamic.XP.Rate.Announce = 1
Dynamic.XP.Rate = 1
Dynamic.Rep.Rate = 1
Dynamic.Gold.Rate = 1

# XP bracket rates (base multiplier applied to all XP sources)
Dynamic.XP.Rate.1-4   = 1.0
Dynamic.XP.Rate.5-9   = 1.2
Dynamic.XP.Rate.10-14 = 1.15
Dynamic.XP.Rate.15-19 = 1.25
Dynamic.XP.Rate.20-24 = 1.35
Dynamic.XP.Rate.25-29 = 1.30
Dynamic.XP.Rate.30-34 = 1.33
Dynamic.XP.Rate.35-39 = 1.36
Dynamic.XP.Rate.40-44 = 1.4
Dynamic.XP.Rate.45-49 = 1.42
Dynamic.XP.Rate.50-54 = 1.44
Dynamic.XP.Rate.55-59 = 1.45
Dynamic.XP.Rate.60-64 = 1.10
Dynamic.XP.Rate.65-69 = 1.15
Dynamic.XP.Rate.70-74 = 1.4
Dynamic.XP.Rate.75-79 = 1.3

# XP source multipliers
Dynamic.XP.Rate.Kill.World   = 1.0
Dynamic.XP.Rate.Kill.Dungeon = 3.0
Dynamic.XP.Rate.Quest.World  = 2.0
Dynamic.XP.Rate.Quest.Dungeon = 3.5
Dynamic.XP.Rate.Explore      = 1.5
Dynamic.XP.BotSoloRate = 0.5
# Reputation bracket rates - bonsai growth curve
Dynamic.Rep.AccountBonus.Enable = 1
Dynamic.Rep.Rate.1-4   = 1.2
Dynamic.Rep.Rate.5-9   = 1.4
Dynamic.Rep.Rate.10-14 = 1.3
Dynamic.Rep.Rate.15-19 = 1.5
Dynamic.Rep.Rate.20-24 = 1.4
Dynamic.Rep.Rate.25-29 = 1.6
Dynamic.Rep.Rate.30-34 = 1.5
Dynamic.Rep.Rate.35-39 = 1.7
Dynamic.Rep.Rate.40-44 = 1.6
Dynamic.Rep.Rate.45-49 = 1.8
Dynamic.Rep.Rate.50-54 = 1.7
Dynamic.Rep.Rate.55-59 = 2.0
Dynamic.Rep.Rate.60-64 = 2.0
Dynamic.Rep.Rate.65-69 = 2.6
Dynamic.Rep.Rate.70-74 = 2.2
Dynamic.Rep.Rate.75-79 = 2.4

# Gold bracket rates - bonsai growth curve
Dynamic.Gold.Rate.1-4   = 1.4
Dynamic.Gold.Rate.5-9   = 1.6
Dynamic.Gold.Rate.10-14 = 1.8
Dynamic.Gold.Rate.15-19 = 2.0
Dynamic.Gold.Rate.20-24 = 1.9
Dynamic.Gold.Rate.25-29 = 2.1
Dynamic.Gold.Rate.30-34 = 2.3
Dynamic.Gold.Rate.35-39 = 2.6
Dynamic.Gold.Rate.40-44 = 2.9
Dynamic.Gold.Rate.45-49 = 3.1
Dynamic.Gold.Rate.50-54 = 3.3
Dynamic.Gold.Rate.55-59 = 3.6
Dynamic.Gold.Rate.60-64 = 2.5
Dynamic.Gold.Rate.65-69 = 2.8
Dynamic.Gold.Rate.70-74 = 2.4
Dynamic.Gold.Rate.75-79 = 2.7

# === Separate multipliers (recommended for high-RPG servers) ===

# === Account XP Bonus (Road to Cap style) ===
Dynamic.XP.AccountBonus.Enable = 1
Dynamic.XP.AccountBonus.PerMaxedChar = 0.25     
Dynamic.XP.AccountBonus.MaxMultiplier = 5.0   
   
Dynamic.Skill.XP.Enable = true


##################################################################################################################
